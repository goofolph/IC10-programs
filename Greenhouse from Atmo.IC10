alias filtration db

define MAXOUTPUTPRESSURE 101
define MINTEMPERATURE 288

s filtration Open 0

start:
yield
l r0 filtration PressureOutput
slt r0 r0 MAXOUTPUTPRESSURE

l r1 filtration TemperatureOutput
s db Setting r1
sgt r1 r1 MINTEMPERATURE
and r0 r0 r1

ls r1 filtration 0 Quantity
ls r2 filtration 1 Quantity
add r1 r1 r2
sgtz r1 r1
and r0 r0 r1
s filtration Mode r0
j start